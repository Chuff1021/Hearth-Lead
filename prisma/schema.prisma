generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── PERMIT DATA ────────────────────────────────────────────

model Permit {
  id               String   @id @default(cuid())
  permitNumber     String   @unique
  source           String   // springfield, ozark, nixa, greene_county, christian_county
  type             String   // new_residential, commercial, remodel, addition, other
  subType          String?  // single_family, multi_family, townhome
  status           String   // applied, approved, in_review, under_inspection, final, co_issued
  propertyAddress  String
  city             String
  county           String   // Greene, Christian
  zip              String?
  parcelNumber     String?
  ownerName        String?
  ownerAddress     String?
  ownerPhone       String?
  ownerEmail       String?
  contractorName   String?
  contractorId     String?
  subdivision      String?
  estimatedValue   Float?
  squareFootage    Float?
  stories          Int?
  dateFiled        DateTime?
  dateApproved     DateTime?
  dateIssued       DateTime?
  dateFinal        DateTime?
  description      String?
  rawData          String?  // JSON blob of original scraped data
  leadScore        Int      @default(0) // 0-100
  leadId           String?
  lead             Lead?    @relation(fields: [leadId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([city])
  @@index([county])
  @@index([type])
  @@index([status])
  @@index([dateFiled])
  @@index([contractorName])
  @@index([subdivision])
  @@index([leadScore])
}

// ─── LEADS ──────────────────────────────────────────────────

model Lead {
  id              String   @id @default(cuid())
  type            String   // permit_lead, website_lead, builder_lead
  status          String   @default("new") // new, contacted, quoted, won, lost
  score           Int      @default(0) // 0-100
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  address         String?
  city            String?
  county          String?
  builderName     String?
  builderId       String?
  builder         Builder? @relation(fields: [builderId], references: [id])
  subdivision     String?
  homeSize        String?  // sq ft range
  budget          String?  // budget range
  fuelPreference  String?  // gas, wood, electric
  style           String?  // modern, traditional, rustic
  timeline        String?  // planning, building, framing, finishing
  source          String?  // organic, direct, referral, permit_data
  sourcePage      String?  // which page they came from
  sourceCta       String?  // which CTA they clicked
  notes           String?
  permits         Permit[]
  outreachLogs    OutreachLog[]
  captures        LeadCapture[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([score])
  @@index([type])
  @@index([city])
  @@index([builderId])
}

// ─── BUILDERS ───────────────────────────────────────────────

model Builder {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  company         String?
  phone           String?
  email           String?
  website         String?
  licenseNumber   String?
  address         String?
  city            String?
  specialties     String?  // JSON array: custom, production, spec, remodel
  avgHomePrice    String?  // price range
  fireplaceRate   Float?   // 0-1, what % of their homes have fireplaces
  relationship    String   @default("unknown") // unknown, contacted, pitched, partner, declined
  notes           String?
  totalPermits    Int      @default(0)
  activePermits   Int      @default(0)
  leads           Lead[]
  outreachLogs    OutreachLog[]
  subdivisions    Subdivision[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([relationship])
  @@index([totalPermits])
}

// ─── SUBDIVISIONS ───────────────────────────────────────────

model Subdivision {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  city            String
  county          String
  zip             String?
  builderId       String?
  builder         Builder? @relation(fields: [builderId], references: [id])
  priceRange      String?
  homeSizeRange   String?
  totalLots       Int?
  activeLots      Int?
  description     String?
  fireplaceNotes  String?  // what fireplace options are popular here
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([city])
  @@index([builderId])
}

// ─── OUTREACH ───────────────────────────────────────────────

model OutreachLog {
  id          String   @id @default(cuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  builderId   String?
  builder     Builder? @relation(fields: [builderId], references: [id])
  type        String   // email, phone, mail, in_person
  direction   String   // outbound, inbound
  subject     String?
  body        String?
  outcome     String?  // no_answer, left_message, spoke, meeting_set, quote_sent
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([builderId])
}

// ─── LEAD CAPTURES (website form submissions) ───────────────

model LeadCapture {
  id            String   @id @default(cuid())
  leadId        String?
  lead          Lead?    @relation(fields: [leadId], references: [id])
  firstName     String
  lastName      String?
  email         String
  phone         String?
  message       String?
  page          String   // which page the form was on
  cta           String?  // which CTA triggered it
  formType      String   // contact, quiz, checklist, consultation
  answers       String?  // JSON blob of quiz answers
  ipAddress     String?
  userAgent     String?
  referrer      String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  createdAt     DateTime @default(now())

  @@index([email])
  @@index([page])
  @@index([formType])
}

// ─── BLOG/SEO CONTENT ───────────────────────────────────────

model BlogPost {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  metaTitle     String?
  metaDescription String?
  excerpt       String?
  content       String   // HTML content
  category      String?  // guide, comparison, local, checklist
  tags          String?  // JSON array
  published     Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([category])
}

// ─── ANALYTICS EVENTS ───────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String   // page_view, cta_click, form_submit, phone_click
  page      String?
  data      String?  // JSON blob
  sessionId String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([page])
  @@index([createdAt])
}
